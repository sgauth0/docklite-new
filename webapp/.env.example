# Optional: Set a custom path for the SQLite database file
# DATABASE_PATH=/path/to/your/docklite.db

# Optional: Set a custom path for the Docker socket
# DOCKER_SOCKET_PATH=/path/to/your/docker.sock

# Agent API URL (default: http://localhost:3000)
# The agent runs on port 3000 and optionally proxies to Next.js on port 3001
AGENT_URL=http://localhost:3000
# Shared token for agent auth (set this in both the app and agent)
# AGENT_TOKEN=replace-with-a-long-random-string
# DOCKLITE_TOKEN=replace-with-a-long-random-string

# Optional: Path to Traefik's acme.json file for SSL certificate info
# Can be comma-separated list of paths to try
# ACME_PATH=/letsencrypt/acme.json

# Enable database debugging/inspection UI (set to true to enable)
# ENABLE_DB_DEBUG=true

# Optional: disable Next.js proxy in headless mode
# NEXTJS_URL=disabled

# Session secret for iron-session (32+ characters recommended)
SESSION_SECRET=replace-with-a-long-random-string
