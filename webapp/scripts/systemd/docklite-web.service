[Unit]
Description=DockLite Web (Next.js)
After=network.target

[Service]
Type=simple
User=docklite
Group=docklite
WorkingDirectory=__INSTALL_DIR__/webapp
EnvironmentFile=/etc/docklite/docklite-web.env
Environment=PORT=3001
ExecStart=/usr/local/bin/bun run start:systemd
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
