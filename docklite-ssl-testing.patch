+func TestHTTPProvider(t *testing.T) {
+	provider := NewHTTPProvider(80)
+
+	t.Run("presents and cleans up token", func(t *testing.T) {
+		domain := "example.com"
+		token := "test-token"
+		keyAuth := "test-key-auth"
