+	if err != nil {
+		t.Fatalf("Failed to create folder_containers table: %v", err)
+	}
+
+	_, err = db.Exec(`
+		CREATE TABLE IF NOT EXISTS backup_destinations (
+			id INTEGER PRIMARY KEY AUTOINCREMENT,
