+func TestSortByPosition(t *testing.T) {
+	t.Run("sorts nodes by position", func(t *testing.T) {
+		nodes := []*folderNode{
+			{Folder: folder{Position: 2}},
+			{Folder: folder{Position: 0}},
+			{Folder: folder{Position: 1}},
+		}
