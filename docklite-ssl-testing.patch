+
+	_, err = db.Exec(`
+		CREATE TABLE IF NOT EXISTS folder_containers (
+			id INTEGER PRIMARY KEY AUTOINCREMENT,
+			folder_id INTEGER NOT NULL,
+			container_id TEXT NOT NULL,
+			position INTEGER DEFAULT 0,
